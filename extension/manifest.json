{
  "manifest_version": 3,
  "name": "UX Tracker MVP",
  "description": "Lightweight local tracker for UX interaction events.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "UX Tracker MVP"
  }
}
